{
  "name": "Thesdel",
  "short_name": "Thesdel",
  "description": "Student Digital Exchange Layer — Campus life, simplified.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#FF6600",
  "orientation": "portrait",
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "id": "com.thesdel.app",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "categories": ["education", "social", "productivity"],
  "prefer_related_applications": false,
  "display_override": ["window-controls-overlay", "minimal-ui"],
  "scope_extensions": [
    {
      "origin": "https://thesdel.com"
    }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing", "navigate-new"]
  },
  "protocol_handlers": [
    {
      "protocol": "mailto",
      "url": "/compose?to=%s"
    },
    {
      "protocol": "web+thesdel",
      "url": "/handle?data=%s"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/feed.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "platform": "wide",
      "label": "Campus feed"
    },
    {
      "src": "/screenshots/cbt.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "platform": "wide",
      "label": "CBT practice"
    },
    {
      "src": "/screenshots/market.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "platform": "wide",
      "label": "Campus market"
    }
  ],
  "shortcuts": [
    {
      "name": "Feed",
      "short_name": "Feed",
      "description": "Campus feed",
      "url": "/feed",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "CBT",
      "short_name": "CBT",
      "description": "Practice exams",
      "url": "/cbt",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Market",
      "short_name": "Market",
      "description": "Campus market",
      "url": "/market",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "DMs",
      "short_name": "DMs",
      "description": "Messages",
      "url": "/dms",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192" }]
    }
  ]
}
